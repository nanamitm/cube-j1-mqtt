#!/system/bin/sh

PT="/tmp/production_tool"

# ── ADB settings ──────────────────────────────────────────────────────────────
# locked_mode only controls ADB-over-network (TCP); USB-cable ADB is left
# alone either way. Skipped entirely when locked_mode is set, so the
# network port never comes up even briefly during install.
if ! grep -q '"locked_mode"[[:space:]]*:[[:space:]]*true' $PT/config.json; then
    setprop service.adb.tcp.port 5555
    setprop persist.adb.tcp.port 5555
    setprop persist.sys.usb.config mtp,adb
    stop adbd
    sleep 1
    start adbd
fi

# ── Wi-Fi client settings ──────────────────────────────────────────────────────
cp $PT/wpa_supplicant.conf /data/misc/wifi/wpa_supplicant.conf
chmod 660 /data/misc/wifi/wpa_supplicant.conf
chown system:wifi /data/misc/wifi/wpa_supplicant.conf

# install LED helper early so it can show Wi-Fi connection progress below
cp $PT/led_effect.sh /data/local/led_effect.sh
chmod 755 /data/local/led_effect.sh

wpa_cli -p /data/misc/wifi/sockets -i wlan0 reconfigure

# ── Blink blue until Wi-Fi association completes (give up after ~5 min) ───────
i=0
while [ $i -lt 500 ]; do
    if wpa_cli -p /data/misc/wifi/sockets -i wlan0 status 2>/dev/null | grep -q '^wpa_state=COMPLETED$'; then
        break
    fi
    /data/local/led_effect.sh blink blue 1
    i=$((i + 1))
done

# ── Install MQTT bridge (persistent, survives USB removal) ────────────────────

# copy config and bridge script to /data/local (always writable)
cp $PT/config.json       /data/local/config.json
cp $PT/mqtt_bridge.py    /data/local/mqtt_bridge.py
cp $PT/config_server.py  /data/local/config_server.py
cp $PT/disable_p2p_ap.sh /data/local/disable_p2p_ap.sh
cp $PT/VERSION           /data/local/cube-j1-mqtt.version
chmod 600 /data/local/config.json
chmod 755 /data/local/mqtt_bridge.py
chmod 755 /data/local/config_server.py
chmod 755 /data/local/disable_p2p_ap.sh
chmod 644 /data/local/cube-j1-mqtt.version

# make root filesystem writable so we can update init RC files
mount -o rw,remount /

# disable wisund (it holds /dev/ttyS1 and blocks our bridge)
cp $PT/wisund_disabled.rc /system/etc/init/wisund.rc

# disable ndeclite_agent (depends on wisund socket, not needed)
cp $PT/ndeclite_disabled.rc /system/etc/init/ndeclite_agent.rc

# install our MQTT bridge as an init service (auto-start on next boot)
cp $PT/mqtt_ha_bridge.rc /system/etc/init/mqtt_ha_bridge.rc

# install config web UI as an init service
cp $PT/config_server.rc /system/etc/init/cubej_web_ui.rc

# install P2P/AP disabler as an init service (auto-runs on every boot,
# the factory CubeJ-xxxxxx AP has no usable credentials - see disable_p2p_ap.sh)
cp $PT/disable_p2p_ap.rc /system/etc/init/disable_p2p_ap.rc

# ── Stop conflicting services immediately ──────────────────────────────────────
stop wisund
stop NDEcLiteAgent
sleep 2

# ── Stop the factory P2P/AP now (init service handles future boots) ───────────
/system/bin/sh /data/local/disable_p2p_ap.sh

# ── Start MQTT bridge immediately via init (survives USB removal and reboot) ───
stop mqtt_ha_bridge 2>/dev/null || true
stop cubej_web_ui 2>/dev/null || true
sleep 1
start mqtt_ha_bridge
start cubej_web_ui

# ── Finish LED (blink white) ───────────────────────────────────────────────
/data/local/led_effect.sh blink white 10
